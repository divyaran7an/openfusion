# Vercel AI Gateway key for real model calls, or paste it in the studio instead
# (Vercel AI Gateway chip -> Save key). A studio-set key takes precedence over this.
AI_GATEWAY_API_KEY=

# OpenRouter key for OpenRouter model calls, routers, and server-side search/fetch.
# Paste it in the studio instead (OpenRouter chip -> Save key), or set it here.
OPENROUTER_API_KEY=
OPENROUTER_APP_TITLE=OpenFusion
OPENROUTER_HTTP_REFERER=

# Optional local API auth. FUSION_API_KEY is a client convenience value.
# FUSION_API_KEYS is the server allowlist, separated by commas or new lines.
# Leave both empty for open local access; set FUSION_API_KEYS to require a Bearer key.
FUSION_API_KEY=
FUSION_API_KEYS=

# Where the active graph is persisted (the council you compose in the studio).
# Defaults to ./.fusion (gitignored). Override to isolate or relocate it.
FUSION_DATA_DIR=

# Optional web extraction/fetch path through Parallel.
PARALLEL_API_KEY=

# Built-in public URL fetch tool. Keep allow/block lists narrow for shared use.
FUSION_WEB_FETCH=1
FUSION_WEB_ALLOW_DOMAINS=
FUSION_WEB_BLOCK_DOMAINS=

# Optional Vercel AI Gateway generation lookup for authoritative cost/provider metadata.
# Set to 0 to skip the extra Vercel AI Gateway generation-info calls.
FUSION_GATEWAY_GENERATION_LOOKUP=1

# Optional OpenRouter generation lookup for authoritative cost/provider metadata.
# Set to 0 to skip the extra OpenRouter generation-info calls.
FUSION_OPENROUTER_GENERATION_LOOKUP=1

# Optional client-facing aliases for apps that reject custom model IDs.
# Format: client-model=workflow-target. Use openfusion or fusion as the target.
# Older preset targets still resolve, but they are not advertised by /v1/models.
FUSION_MODEL_ALIASES=

# Optional product-level prompt applied to panel, judge, synthesis, and outer controller calls.
# Do not commit private system prompts.
FUSION_SYSTEM_PROMPT=

# Local filesystem tools. Keep roots narrow.
FUSION_LOCAL_ROOTS=
FUSION_LOCAL_TOOLS=1

# Local harness execution. Claude Code and Codex run as their own official CLIs
# in print / read-only mode and become real, runnable council nodes. No API
# keys, no token scraping. They connect automatically once the CLI is installed,
# local auth or provider credentials are present. The first run still verifies
# the upstream account can execute.
# These flags are an optional opt-OUT. Set one to 0 to force that harness off even
# when its CLI is present. Reference a harness model anywhere a model id is accepted,
# namespaced by harness, e.g. claude-code/opus, claude-code/sonnet, codex/gpt-5.5.
# Thinking budget (minimal|low|medium|high|max) is set per node, not here; it maps to
# Claude Code --effort, Codex model_reasoning_effort, Vercel AI Gateway reasoning, and
# OpenRouter reasoning.
# FUSION_CODEX_HARNESS=0         # uncomment to disable the Codex harness
FUSION_CODEX_COMMAND=codex
# FUSION_CODEX_HOME=             # optional CODEX_HOME override (e.g. a second account)
# FUSION_CODEX_ENV_JSON=         # optional per-run env overlay for the Codex process
# FUSION_CLAUDE_CODE_HARNESS=0   # uncomment to disable the Claude Code harness
FUSION_CLAUDE_CODE_COMMAND=claude
# FUSION_CLAUDE_CODE_HOME=       # optional HOME override to isolate a Claude account
# FUSION_CLAUDE_CODE_ENV_JSON=   # optional per-run env overlay for the Claude process
FUSION_HARNESS_TIMEOUT_MS=600000
FUSION_HARNESS_SCRATCH_ROOT=/tmp/fusion-harness

# Advanced harness examples:
# - Use FUSION_CODEX_HOME to point Codex at a separate signed-in CODEX_HOME.
# - Use FUSION_CLAUDE_CODE_HOME to point Claude Code at a separate signed-in HOME.
# - Use *_ENV_JSON only when the harness needs source-specific env vars.
#   If Claude Code is routed through OpenRouter with ANTHROPIC_AUTH_TOKEN, that
#   run is billed by OpenRouter, not by your Claude subscription.
# FUSION_CLAUDE_CODE_ENV_JSON={"ANTHROPIC_BASE_URL":"https://openrouter.ai/api","ANTHROPIC_AUTH_TOKEN":"<openrouter-key>","ANTHROPIC_API_KEY":""}

# Optional durable run storage through Vercel/Upstash Redis.
KV_REST_API_URL=
KV_REST_API_TOKEN=
