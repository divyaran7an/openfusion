{
  "$schema": "https://opencode.ai/config.json",
  "model": "fusion/openfusion",
  "small_model": "fusion/openfusion",
  "provider": {
    "fusion": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenFusion",
      "options": {
        "baseURL": "http://127.0.0.1:3001/v1",
        "apiKey": "local-fusion",
        "timeout": 900000,
        "chunkTimeout": 120000
      },
      "models": {
        "fusion": {
          "name": "OpenFusion",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        },
        "openfusion": {
          "name": "OpenFusion",
          "limit": {
            "context": 200000,
            "output": 65536
          }
        }
      }
    }
  }
}
